# Test Refinements Round 17

# 1. String Predicates
print("--- Testing String Predicates ---")
print(f"isdigit('123') = {isdigit('123')}")     # True
print(f"isdigit('12.3') = {isdigit('12.3')}")   # False
print(f"isdigit('') = {isdigit('')}")           # False

print(f"isdecimal('123') = {isdecimal('123')}") # True
print(f"isnumeric('123') = {isnumeric('123')}") # True

# 2. String Justification
print("\n--- Testing String Justification ---")
print(f"ljust('flux', 10) = '{ljust('flux', 10)}'")         # 'flux      '
print(f"ljust('flux', 10, '*') = '{ljust('flux', 10, '*')}'") # 'flux******'
print(f"rjust('flux', 10) = '{rjust('flux', 10)}'")         # '      flux'
print(f"rjust('flux', 10, '-') = '{rjust('flux', 10, '-')}'") # '------flux'

# 3. Math Functions
print("\n--- Testing Math Functions ---")
print(f"gcd(48, 18) = {gcd(48, 18)}")     # 6
print(f"lcm(48, 18) = {lcm(48, 18)}")     # 144
print(f"isclose(3.14, 3.1400000001) = {isclose(3.14, 3.1400000001)}") # True
print(f"isclose(3.14, 3.15) = {isclose(3.14, 3.15)}")             # False

# 4. Attribute Access (getattr/hasattr)
print("\n--- Testing getattr/hasattr ---")
let s = "flux"
print(f"hasattr(s, 'ljust') = {hasattr(s, 'ljust')}")
print(f"hasattr(s, 'gcd') = {hasattr(s, 'gcd')}") # False
print(f"getattr(s, 'upper') = {getattr(s, 'upper')}")

print("\nAll Round 17 refinement tests completed!")
